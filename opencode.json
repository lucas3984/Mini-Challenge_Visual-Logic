{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "bash": {
            "*": "allow",
            "git *": "deny"
        }
    },
    "agent": {
        "plan": {
            "mode": "primary",
            "prompt": "You are in plan mode (read-only). For ANY git operation (status, diff, log, commit, push, pull, branch, checkout, merge, etc.), you MUST immediately delegate to @git-controller via the task tool. Never attempt git commands directly via bash (it is denied). Always use git-controller for git tasks.",
            "permission": {
                "task": {
                    "*": "deny",
                    "git-controller": "allow"
                },
                "edit": "deny",
                "bash": "deny",
                "stitch_generate*": "deny",
                "stitch_create*": "deny",
                "stitch_update*": "deny",
                "stitch_apply*": "deny",
                "stitch_edit*": "deny"
            }
        },
        "git-controller": {
            "description": "Review and plan commits, handles git",
            "mode": "subagent",
            "prompt": "You are the git manager. Focus on objectivity, clarity and mantainability.",
            "permission": {
                "edit": "deny",
                "bash": {
                    "*": "deny",
                    "git *": "ask",
                    "git diff *": "allow",
                    "git log *": "allow",
                    "git status *": "allow",
                    "git show *": "allow",
                    "git branch *": "ask",
                    "git branch": "allow",
                    "git branch -r": "allow",
                    "git branch -a": "allow",
                    "git branch -v": "allow",
                    "git branch --show-current": "allow",
                    "git switch *": "allow",
                    "git switch -*": "ask",
                    "git switch": "allow",
                    "git ls*": "allow",
                    "git remote": "allow",
                    "git remote -v": "allow",
                    "git remote show *": "allow",
                    "git tag -l *": "allow",
                    "git config --list": "allow",
                    "git config --get *": "allow",
                    "git stash list": "allow",
                    "git reflog": "allow",
                    "git show-ref *": "allow",
                    "git rev-parse *": "allow",
                    "git merge-base *": "allow",
                    "git shortlog *": "allow",
                    "git describe *": "allow"
                }
            },
            "temperature": 0.0
        }
    },
    "mcp": {
        "stitch": {
        "type": "remote",
        "url": "https://stitch.googleapis.com/mcp",
        "enabled": true,
            "headers": {
                "X-Goog-Api-Key": "{env:STITCH_API_KEY}"
            },
        "timeout": 60000
        }
    }
}